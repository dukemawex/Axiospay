# API Environment Variables
DATABASE_URL=postgresql://axiospay:secret@localhost:5432/axiospay
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRY=7d

# Interswitch
INTERSWITCH_CLIENT_ID=your-client-id
INTERSWITCH_SECRET_KEY=your-secret-key
INTERSWITCH_BASE_URL=https://sandbox.interswitchng.com

# Email
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=noreply@axiospay.com

# Twilio SMS
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
OTP_EXPIRY_MINUTES=10
